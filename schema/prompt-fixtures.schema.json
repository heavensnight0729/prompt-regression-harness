{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/heavensnight0729/prompt-regression-harness/schema/prompt-fixtures.schema.json",
  "title": "Prompt Regression Harness Fixtures",
  "description": "Local fixture format for prompt-regression-harness.",
  "oneOf": [
    { "$ref": "#/$defs/caseArray" },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["cases"],
      "properties": {
        "cases": { "$ref": "#/$defs/caseArray" }
      }
    }
  ],
  "$defs": {
    "caseArray": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/case" }
    },
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "prompt", "actualOutput", "assertions"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "prompt": {
          "type": "string"
        },
        "actualOutput": {
          "type": "string"
        },
        "assertions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/assertion" }
        }
      }
    },
    "assertion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "value"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "contains",
            "exact",
            "matches_regex",
            "not_contains"
          ]
        },
        "value": {
          "type": "string"
        }
      }
    }
  }
}
